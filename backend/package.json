{
  "name": "elarion-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node -e \"require('dotenv/config'); require('./src/db/seeds/initial-data').runSeeds().then(() => process.exit(0)).catch((e: unknown) => { console.error(e); process.exit(1); })\""
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^4.3.5",
    "jose": "^5.2.3",
    "pg": "^8.11.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
